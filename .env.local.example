# ---------------------------------------------------------------------------
# Copy this file to .env.local for local development.
# On Vercel, set these in the project's Environment Variables settings.
# ---------------------------------------------------------------------------

# REQUIRED — long random string used to sign admin JWTs.
# Generate one: openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-string

# Turso database connection — get these from the Turso dashboard or CLI:
#   turso db show kitchen-lover --url
#   turso db tokens create kitchen-lover
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Admin credentials seeded on first startup (when the users table is empty).
# Set these before deploying — changing them after first run has no effect
# unless you clear the users table in Turso first.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
