# ---------------------------------------------------------------------------
# Copy this file to .env.local for local development.
# On Render, set these in the service's Environment tab.
# ---------------------------------------------------------------------------

# REQUIRED — long random string used to sign admin JWTs.
# Generate one: openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-string

# Path to the SQLite database file.
# Locally: omit this line and the file will be created at ./data/kitchen-lover.db
# On Render: set to the mount path of your Persistent Disk, e.g. /data/kitchen-lover.db
SQLITE_DB_PATH=/data/kitchen-lover.db

# Admin credentials seeded on first startup (when the users table is empty).
# Change these before deploying — or set them here and redeploy once to reseed.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
1 